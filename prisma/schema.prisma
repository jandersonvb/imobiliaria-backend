generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AgencyMemberRole {
  OWNER
  MANAGER
  BROKER
  ASSISTANT
}

enum PropertyPurpose {
  SALE
  RENT
  SEASONAL
}

enum PropertyType {
  HOUSE
  APARTMENT
  LAND
  FARM
  COMMERCIAL
  OFFICE
  WAREHOUSE
  RURAL
  DEVELOPMENT
}

enum PropertyStatus {
  DRAFT
  AVAILABLE
  RESERVED
  NEGOTIATION
  SOLD
  RENTED
  INACTIVE
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  VISIT_SCHEDULED
  VISITED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  memberships  AgencyMember[]
  leads        Lead[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Agency {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  creci       String?
  phone       String?
  email       String?
  description String?
  city        String?
  state       String?
  members     AgencyMember[]
  properties  Property[]
  leads       Lead[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model AgencyMember {
  id       String           @id @default(cuid())
  agencyId String
  userId   String
  role     AgencyMemberRole
  agency   Agency           @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([agencyId, userId])
}

model Property {
  id               String          @id @default(cuid())
  agencyId         String
  code             String
  slug             String          @unique
  title            String
  description      String
  purpose          PropertyPurpose
  type             PropertyType
  status           PropertyStatus  @default(DRAFT)
  salePrice        Decimal?        @db.Decimal(14, 2)
  rentPrice        Decimal?        @db.Decimal(14, 2)
  bedrooms         Int?
  bathrooms        Int?
  parkingSpaces    Int?
  totalArea        Decimal?        @db.Decimal(10, 2)
  neighborhood     String
  city             String
  state            String
  latitude         Float?
  longitude        Float?
  coverImageUrl    String?
  isFeatured       Boolean         @default(false)
  agency           Agency          @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  leads            Lead[]
  images           PropertyImage[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([agencyId, code])
  @@index([city, state])
  @@index([purpose, type, status])
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  publicId   String?
  sortOrder  Int      @default(0)
  isCover    Boolean  @default(false)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([propertyId, sortOrder])
}

model Lead {
  id         String    @id @default(cuid())
  agencyId   String
  propertyId String?
  customerId String?
  name       String
  email      String?
  phone      String?
  message    String?
  notes      String?
  stage      LeadStage @default(NEW)
  consentAt  DateTime  @default(now())
  agency     Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  customer   User?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([agencyId, stage])
  @@index([propertyId])
}
